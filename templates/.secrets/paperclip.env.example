# Paperclip ↔ CortexOS bridge secrets.
# Install path: /opt/cortexos/.secrets/paperclip.env  (chmod 600, owner cortex:cortex)

# Paperclip API base URL (Tailscale-only host).
PAPERCLIP_API_URL=https://paperclip.example.internal

# Bearer token minted via /api/agents/:id/keys for the bridge identity.
PAPERCLIP_API_KEY=

# Shared secret for inbound webhook (Authorization: Bearer ...).
# Generate: openssl rand -hex 32
PAPERCLIP_WEBHOOK_SECRET=

# Bridge HTTP port (loopback only; Caddy fronts /paperclip/heartbeat).
BRIDGE_PORT=8089

# NATS endpoint shared with cortex-consumer.
NATS_URL=nats://127.0.0.1:4222

# HMAC secret for NATS envelopes. MUST match cortex-consumer's CORTEX_NATS_HMAC.
CORTEX_NATS_HMAC=

# Postgres DSN for paperclip_ticket_link (dashboard DB).
PG_DSN=postgres://cortex:cortex@127.0.0.1:5432/cortex

# OS family tag echoed by /healthz (ubuntu|debian|unknown).
CORTEX_OS_FAMILY=unknown
