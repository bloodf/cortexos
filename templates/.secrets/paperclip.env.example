# Paperclip ↔ Hermes adapter secrets.
# Install path: /opt/cortexos/.secrets/paperclip.env  (chmod 600, owner cortex:cortex)

# Paperclip API base URL.
# Local compatibility proxy listens on 3033; the Paperclip app listens on 3034.
# Tailscale serves the UI/API externally on 3033.
PAPERCLIP_API_URL=http://127.0.0.1:3033

# Bearer token minted for Paperclip API access.
PAPERCLIP_API_KEY=

# Hermes Paperclip adapter selection.
PAPERCLIP_ADAPTER=hermes_local
HERMES_PROFILE_MAP='{"primary":"primary","secondary":"secondary"}'
HERMES_PRIMARY_URL=http://127.0.0.1:18691/v1
HERMES_SECONDARY_URL=http://127.0.0.1:18692/v1

PAPERCLIP_COMPANY_ID=
BOARD_TOKEN=
