{
  "schema_version": 1,
  "header": {
    "emoji": "✅",
    "title": "{factory_slug}: {stage} Complete",
    "subtitle": "Pipeline advancing to next stage"
  },
  "sections": [
    {
      "type": "kv",
      "items": [
        ["Factory", "{factory_slug}"],
        ["Stage", "{stage}"],
        ["Result", "{result}"],
        ["Duration", "{duration_ms}ms"]
      ]
    },
    {
      "type": "text",
      "markdown": "{summary}"
    }
  ],
  "context": {
    "factory_slug": "{factory_slug}",
    "stage": "{stage}",
    "ts": "{ts}"
  }
}
