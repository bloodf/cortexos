{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortexos/templates/messages/schema.json",
  "title": "CortexOS Canonical Rich-Block Envelope",
  "description": "Channel-agnostic message envelope. Hermes plugins render per platform.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "header", "sections", "context"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Envelope schema version. Increment on breaking changes."
    },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["emoji", "title"],
      "properties": {
        "emoji": {
          "type": "string",
          "description": "Lead emoji (Unicode or shortcode)."
        },
        "title": {
          "type": "string",
          "maxLength": 120
        },
        "subtitle": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "title": "kv-block",
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "items"],
            "properties": {
              "type": { "type": "string", "const": "kv" },
              "items": {
                "type": "array",
                "items": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "prefixItems": [
                    { "type": "string" },
                    { "type": "string" }
                  ],
                  "items": { "type": "string" }
                }
              }
            }
          },
          {
            "title": "text-block",
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "markdown"],
            "properties": {
              "type": { "type": "string", "const": "text" },
              "markdown": { "type": "string" }
            }
          },
          {
            "title": "code-block",
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "body"],
            "properties": {
              "type": { "type": "string", "const": "code" },
              "lang": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        ]
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "style"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "style": {
            "type": "string",
            "enum": ["primary", "danger", "default", "warning"]
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["factory_slug", "stage", "ts"],
      "properties": {
        "factory_slug": { "type": "string" },
        "stage": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" },
        "approval_id": { "type": "string" }
      }
    }
  }
}
