{
  "schema_version": 1,
  "header": {
    "emoji": "💓",
    "title": "Consumer Heartbeat",
    "subtitle": "Uptime: {uptime_s}s"
  },
  "sections": [
    {
      "type": "kv",
      "items": [
        ["Circuit", "{circuit_state}"],
        ["Pending approvals", "{pending_approvals}"],
        ["Messages received", "{messages_received_total}"],
        ["DLQ total", "{messages_dlq_total}"],
        ["OpenClaw errors", "{openclaw_http_errors_total}"]
      ]
    }
  ],
  "context": {
    "factory_slug": "cortex-consumer",
    "stage": "heartbeat",
    "ts": "{ts}"
  }
}
