{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortexos/nats/schemas/cortex.alert.json",
  "title": "cortex.alert.*",
  "description": "Published for any platform alert. Subject: cortex.alert.<kind>",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "severity", "ts"],
  "properties": {
    "kind": {
      "type": "string",
      "description": "Alert kind slug (e.g. approval-stalled, circuit-open, health-degraded)."
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "error", "critical"]
    },
    "title": { "type": "string" },
    "body": { "type": "string" },
    "source": { "type": "string" },
    "factory_slug": { "type": "string" },
    "approval_id": { "type": "string" },
    "stage": { "type": "string" },
    "ts": {
      "type": "string",
      "format": "date-time"
    }
  }
}
