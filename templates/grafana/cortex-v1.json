{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "CortexOS v1.0 — consumer + approval + circuit breaker + audit observability",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Consumer — Message Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "rate(messages_received_total[1m])", "legendFormat": "received/s", "refId": "A" },
        { "expr": "rate(messages_acked_total[1m])", "legendFormat": "acked/s", "refId": "B" },
        { "expr": "rate(messages_nacked_total[1m])", "legendFormat": "nacked/s", "refId": "C" },
        { "expr": "rate(messages_dlq_total[1m])", "legendFormat": "dlq/s", "refId": "D" }
      ],
      "title": "Message Rate (per second)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        { "expr": "rate(openclaw_http_ok_total[1m])", "legendFormat": "ok/s", "refId": "A" },
        { "expr": "rate(openclaw_http_errors_total[1m])", "legendFormat": "errors/s", "refId": "B" }
      ],
      "title": "OpenClaw HTTP Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "NATS JetStream",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        { "expr": "cortex_consumer_pending_approvals", "legendFormat": "pending approvals", "refId": "A" }
      ],
      "title": "Pending Approvals",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        { "expr": "cortex_consumer_last_message_age_seconds", "legendFormat": "last message age (s)", "refId": "A" }
      ],
      "title": "Last Message Age",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Circuit Breaker + Security",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 19 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "cortex_consumer_circuit_state{state=\"open\"}", "legendFormat": "circuit open", "refId": "A" }
      ],
      "title": "Circuit Breaker State",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 19 },
      "id": 9,
      "targets": [
        { "expr": "increase(hmac_reject_total[5m])", "legendFormat": "HMAC rejects/5m", "refId": "A" },
        { "expr": "increase(nonce_replay_total[5m])", "legendFormat": "nonce replays/5m", "refId": "B" }
      ],
      "title": "Security Events",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 19 },
      "id": 10,
      "targets": [
        { "expr": "increase(approval_stall_total[15m])", "legendFormat": "stalled approvals/15m", "refId": "A" }
      ],
      "title": "Approval Timeouts",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cortexos", "consumer", "nats"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CortexOS v1.0",
  "uid": "cortexos-v1",
  "version": 1
}
