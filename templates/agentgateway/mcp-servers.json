{
  "mcp_servers": {
    "claude-context": {
      "command": "npx",
      "args": [
        "-y",
        "@zilliz/claude-context-mcp@latest"
      ],
      "env": {
        "EMBEDDING_MODEL": "${EMBEDDING_MODEL}",
        "EMBEDDING_PROVIDER": "${EMBEDDING_PROVIDER}",
        "MILVUS_ADDRESS": "${MILVUS_ADDRESS}",
        "MILVUS_TOKEN": "${MILVUS_TOKEN}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "expo": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.expo.dev/mcp",
        "--auth-timeout",
        "180",
        "--debug"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ]
    },
    "markitdown": {
      "command": "uvx",
      "args": [
        "markitdown-mcp"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "semble": {
      "command": "uvx",
      "args": [
        "--from",
        "semble[mcp]",
        "semble"
      ]
    },
    "sequentialthinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "time": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp-server-time",
        "python",
        "-m",
        "mcp_server_time",
        "--local-timezone",
        "${CORTEX_LOCAL_TIMEZONE}"
      ]
    },
    "minimax": {
      "command": "npx",
      "args": [
        "-y",
        "minimax-mcp-js"
      ],
      "env": {
        "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
        "MINIMAX_MCP_BASE_PATH": "${MCP_MINIMAX_BASE_PATH}",
        "MINIMAX_API_HOST": "${MINIMAX_API_HOST}",
        "MINIMAX_API_RESOURCE_MODE": "${MINIMAX_API_RESOURCE_MODE}"
      }
    },
    "web-reader": {
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "${ZAI_WEB_READER_AUTHORIZATION}"
      }
    },
    "web-search-prime": {
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "${ZAI_WEB_SEARCH_PRIME_AUTHORIZATION}"
      }
    },
    "zai-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "env": {
        "Z_AI_MODE": "${Z_AI_MODE}",
        "Z_AI_API_KEY": "${Z_AI_API_KEY}"
      }
    },
    "zread": {
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "${ZAI_ZREAD_AUTHORIZATION}"
      }
    }
  }
}
