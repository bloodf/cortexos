{
  "description": "Cross-model antagonist review routing. All calls via 9Router API.",
  "api": {
    "base_url": "http://localhost:11434/v1",
    "auth_env": "NINEROUTER_API_KEY"
  },
  "routing": {
    "gpt-5.5": {
      "provider": "OpenAI",
      "display_name": "OpenAI GPT-5.5",
      "reviewer_model": "cc/claude-opus-4-7",
      "reviewer_display": "Anthropic Claude Opus 4.7"
    },
    "claude-opus-4-7": {
      "provider": "Anthropic",
      "display_name": "Anthropic Claude Opus 4.7",
      "reviewer_model": "cx/gpt-5.5",
      "reviewer_display": "OpenAI GPT-5.5"
    },
    "kimi-latest": {
      "provider": "Moonshot",
      "display_name": "Moonshot Kimi Latest",
      "reviewer_model": "cc/claude-opus-4-7",
      "reviewer_display": "Anthropic Claude Opus 4.7"
    },
    "MiniMax-M2.7-highspeed": {
      "provider": "MiniMax",
      "display_name": "MiniMax M2.7 Highspeed",
      "reviewer_model": "cx/gpt-5.5",
      "reviewer_display": "OpenAI GPT-5.5"
    }
  },
  "review_triggers": {
    "stage:triage": {
      "agent_role": "cto",
      "review_type": "triage-assessment",
      "description": "Review CTO triage: sizing, component, feasibility"
    },
    "stage:approved": {
      "agent_role": "pm",
      "review_type": "sprint-plan",
      "description": "Review PM sprint breakdown and task assignment"
    },
    "stage:design": {
      "agent_role": "uxui",
      "review_type": "design-spec",
      "description": "Review design spec: usability, accessibility, missing states"
    },
    "stage:sprint-planned": {
      "agent_role": "engineer",
      "review_type": "implementation-plan",
      "description": "Review engineer approach: risks, gaps, test scenarios"
    },
    "stage:code-review": {
      "agent_role": "staff-eng",
      "review_type": "code-review-audit",
      "description": "Review the code review itself: missed bugs, security, perf"
    },
    "epic-creation": {
      "agent_role": "ceo",
      "review_type": "epic-quality",
      "description": "Review epic: scope clarity, measurability, requirements"
    },
    "acceptance-criteria": {
      "agent_role": "po",
      "review_type": "acceptance-criteria",
      "description": "Review AC: completeness, edge cases, testability"
    }
  },
  "rules": {
    "max_revision_cycles": 1,
    "escalate_on_second_block": true,
    "post_as": "github-issue-comment",
    "never_same_provider": true
  }
}
