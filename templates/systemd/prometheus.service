[Unit]
Description=Prometheus monitoring server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=prometheus
Group=prometheus
ExecStart=/usr/local/bin/prometheus --config.file=/etc/prometheus/prometheus.yml --storage.tsdb.path=/var/lib/prometheus --storage.tsdb.retention.time=30d --web.listen-address=127.0.0.1:9090 --web.route-prefix=/prometheus
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
