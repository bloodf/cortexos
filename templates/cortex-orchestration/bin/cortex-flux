#!/usr/bin/env bash
# cortex-flux — V0 DuckFlux-subset workflow runner
#
# Supports:
#   - participants type: exec, emit
#   - flow: sequential, parallel, if/then/else, named/anonymous inline, refs
#   - defaults.timeout (per-stage docker timeout)
#   - inputs.<name>.default (env injected as workflow.inputs.*)
#   - emit publishes to NATS via cortex-bus
#
# Not yet supported:
#   http, mcp, workflow (sub-workflow), loop, retry, when guards, CEL full
#
# Usage:
#   cortex-flux <workflow.yml> [--repo-dir DIR] [--input KEY=VAL]... [--no-bus]
#
# Exit codes:
#   0 ok | 1 stage failed | 2 invalid workflow | 3 runtime error
set -u
set -o pipefail

CORTEX_HOME="${CORTEX_HOME:-/opt/cortex}"
BUS_BIN="${CORTEX_BUS:-$CORTEX_HOME/bin/cortex-bus}"
LOG_DIR="$CORTEX_HOME/logs"
mkdir -p "$LOG_DIR"

WORKFLOW=""
REPO_DIR="$PWD"
NO_BUS=0
declare -a INPUT_OVERRIDES=()

while [ $# -gt 0 ]; do
  case "$1" in
    --repo-dir) REPO_DIR="$2"; shift 2 ;;
    --input)    INPUT_OVERRIDES+=("$2"); shift 2 ;;
    --no-bus)   NO_BUS=1; shift ;;
    -h|--help)  sed -n '2,18p' "$0"; exit 0 ;;
    -*) echo "unknown flag: $1" >&2; exit 2 ;;
    *) [ -z "$WORKFLOW" ] && WORKFLOW="$1" || { echo "extra arg: $1" >&2; exit 2; }; shift ;;
  esac
done

[ -n "$WORKFLOW" ] && [ -f "$WORKFLOW" ] || { echo "error: workflow file required: $WORKFLOW" >&2; exit 2; }

# YAML → JSON
WF_JSON="$(python3 -c "import sys,yaml,json; print(json.dumps(yaml.safe_load(open('$WORKFLOW'))))" 2>&1)"
printf '%s' "$WF_JSON" | jq empty 2>/dev/null || { echo "error: workflow yaml parse failed: $WF_JSON" >&2; exit 2; }

WF_ID="$(printf '%s' "$WF_JSON"   | jq -r '.id // "unnamed"')"
WF_VER="$(printf '%s' "$WF_JSON"  | jq -r '.version // "0.7"')"
WF_NAME="$(printf '%s' "$WF_JSON" | jq -r '.name // .id // "workflow"')"
RUN_ID="$(date -u +%Y%m%dT%H%M%S)-$(printf '%s' "$WF_ID-$$-$RANDOM" | sha1sum | head -c 8)"
RUN_LOG="$LOG_DIR/$RUN_ID.log"

echo "[cortex-flux] $WF_NAME id=$WF_ID v=$WF_VER run=$RUN_ID" | tee -a "$RUN_LOG"

bus_emit() {
  [ "$NO_BUS" = "1" ] && return 0
  local subject="$1" payload="$2"
  "$BUS_BIN" pub "$subject" "$payload" >/dev/null 2>&1 || true
}

# Inputs context
declare -A INPUTS
while read -r k; do
  [ -z "$k" ] && continue
  v="$(printf '%s' "$WF_JSON" | jq -r --arg k "$k" '.inputs[$k].default // ""')"
  INPUTS["$k"]="$v"
done < <(printf '%s' "$WF_JSON" | jq -r '.inputs // {} | keys[]')
for ovr in "${INPUT_OVERRIDES[@]}"; do
  k="${ovr%%=*}"; v="${ovr#*=}"
  INPUTS["$k"]="$v"
done

resolve_cel_literal() {
  # V0 CEL subset: only `workflow.inputs.<key>` and bare quoted literals
  local expr="$1"
  if [[ "$expr" =~ ^workflow\.inputs\.([a-zA-Z_][a-zA-Z0-9_]*)$ ]]; then
    printf '%s' "${INPUTS[${BASH_REMATCH[1]}]:-}"; return
  fi
  if [[ "$expr" =~ ^\".*\"$ ]]; then printf '%s' "${expr:1:${#expr}-2}"; return; fi
  printf '%s' "$expr"
}

run_exec() {
  local name="$1" run="$2" cwd="$3" image="$4" timeout_s="$5"
  local stage_log="$LOG_DIR/$RUN_ID-$name.log"
  local target="$REPO_DIR"
  [ -n "$cwd" ] && target="$REPO_DIR/$cwd"
  echo "[stage:$name] image=$image cwd=$target" | tee -a "$RUN_LOG"
  bus_emit "cortex.workflow.$WF_ID.run.stage" \
    "$(jq -nc --arg n "$name" --arg s pending --arg r "$RUN_ID" '{runId:$r,stage:$n,status:$s}')"
  if [ -z "$image" ]; then
    ( cd "$target" && timeout "$timeout_s" bash -ec "$run" ) >"$stage_log" 2>&1
  else
    timeout "$timeout_s" docker run --rm \
      -v "$target:/work" -w /work \
      --user "$(id -u):$(id -g)" \
      -e CI=true -e CORTEX_RUN_ID="$RUN_ID" \
      "$image" sh -ec "$run" >"$stage_log" 2>&1
  fi
  local rc=$?
  if [ $rc -eq 0 ]; then
    echo "[stage:$name] PASS" | tee -a "$RUN_LOG"
    bus_emit "cortex.workflow.$WF_ID.run.stage" \
      "$(jq -nc --arg n "$name" --arg s success --arg r "$RUN_ID" '{runId:$r,stage:$n,status:$s}')"
    return 0
  fi
  echo "[stage:$name] FAIL rc=$rc — last lines:" | tee -a "$RUN_LOG"
  tail -50 "$stage_log" | tee -a "$RUN_LOG"
  bus_emit "cortex.workflow.$WF_ID.run.stage" \
    "$(jq -nc --arg n "$name" --arg s failure --arg r "$RUN_ID" --argjson rc "$rc" '{runId:$r,stage:$n,status:$s,exitCode:$rc}')"
  return 1
}

run_emit() {
  local event="$1" payload="$2"
  echo "[emit] $event" | tee -a "$RUN_LOG"
  bus_emit "$event" "$payload"
}

resolve_participant() {
  # echo "<type> <run> <cwd> <image> <timeout>" for exec
  # echo "EMIT <event> <payload_json>"          for emit
  local pjson="$1"
  local type
  type="$(printf '%s' "$pjson" | jq -r '.type // ""')"
  case "$type" in
    exec)
      local run cwd image timeout
      run="$(printf '%s' "$pjson"     | jq -r '.run')"
      cwd="$(printf '%s' "$pjson"     | jq -r '.cwd // ""')"
      image="$(printf '%s' "$pjson"   | jq -r '.image // ""')"
      timeout="$(printf '%s' "$pjson" | jq -r '.timeout // "600"')"
      [[ "$timeout" =~ ^[0-9]+[smhd]$ ]] && {
        local n="${timeout%[smhd]}" u="${timeout: -1}"
        case "$u" in s) timeout="$n";; m) timeout="$((n*60))";; h) timeout="$((n*3600))";; d) timeout="$((n*86400))";; esac
      }
      printf 'EXEC\n%s\n%s\n%s\n%s\n' "$run" "$cwd" "$image" "$timeout"
      ;;
    emit)
      local event payload
      event="$(printf '%s' "$pjson" | jq -r '.event')"
      payload="$(printf '%s' "$pjson" | jq -c '.payload // {}')"
      # Resolve CEL on payload values (one level deep)
      payload="$(printf '%s' "$payload" | jq -c 'walk(if type == "string" then . else . end)')"
      printf 'EMIT\n%s\n%s\n' "$event" "$payload"
      ;;
    "")
      echo "ERR: participant missing .type" >&2; return 2 ;;
    *)
      echo "ERR: unsupported participant type: $type (V0 supports exec, emit)" >&2; return 2 ;;
  esac
}

# Lookup participant JSON by name (reusable in participants{} block or inline named)
lookup_participant() {
  local name="$1"
  local out
  out="$(printf '%s' "$WF_JSON" | jq -c --arg n "$name" '.participants[$n] // empty')"
  [ -n "$out" ] && { printf '%s' "$out"; return 0; }
  echo "ERR: unknown participant: $name" >&2; return 2
}

execute_step() {
  local step_json="$1" depth="${2:-0}"
  # Determine step kind
  local kind type
  type="$(printf '%s' "$step_json" | jq -r 'type')"
  if [ "$type" = "string" ]; then
    # Reference by name
    local name; name="$(printf '%s' "$step_json" | jq -r '.')"
    local pjson; pjson="$(lookup_participant "$name")" || return 2
    pjson="$(printf '%s' "$pjson" | jq --arg n "$name" '. + {name:$n}')"
    execute_step "$pjson" "$depth"
    return $?
  fi
  # Object — control flow or inline participant
  if printf '%s' "$step_json" | jq -e '.parallel' >/dev/null; then
    local cnt; cnt="$(printf '%s' "$step_json" | jq -r '.parallel | length')"
    declare -a pids=()
    for i in $(seq 0 $((cnt-1))); do
      local sub; sub="$(printf '%s' "$step_json" | jq -c ".parallel[$i]")"
      ( execute_step "$sub" "$((depth+1))" ) &
      pids+=($!)
    done
    local fail=0
    for p in "${pids[@]}"; do wait "$p" || fail=1; done
    return $fail
  fi
  if printf '%s' "$step_json" | jq -e '.if' >/dev/null; then
    local cond; cond="$(printf '%s' "$step_json" | jq -r '.if.condition')"
    local lhs op rhs result=0
    if [[ "$cond" =~ ^(.+)[[:space:]]*==[[:space:]]*(.+)$ ]]; then
      lhs="$(resolve_cel_literal "$(echo "${BASH_REMATCH[1]}" | xargs)")"
      rhs="$(resolve_cel_literal "$(echo "${BASH_REMATCH[2]}" | xargs)")"
      [ "$lhs" = "$rhs" ] && result=1
    fi
    local branch="else"
    [ "$result" = "1" ] && branch="then"
    local steps_len; steps_len="$(printf '%s' "$step_json" | jq -r ".if.$branch // [] | length")"
    for i in $(seq 0 $((steps_len-1))); do
      local sub; sub="$(printf '%s' "$step_json" | jq -c ".if.$branch[$i]")"
      execute_step "$sub" "$((depth+1))" || return $?
    done
    return 0
  fi
  # Inline participant
  local name; name="$(printf '%s' "$step_json" | jq -r '.as // .name // ""')"
  [ -z "$name" ] && name="step-$RANDOM"
  local pjson="$step_json"
  local resolved; resolved="$(resolve_participant "$pjson")" || return 2
  local rk; rk="$(printf '%s' "$resolved" | head -1)"
  if [ "$rk" = "EXEC" ]; then
    local run cwd image timeout
    run="$(printf '%s'   "$resolved" | sed -n '2p')"
    cwd="$(printf '%s'   "$resolved" | sed -n '3p')"
    image="$(printf '%s' "$resolved" | sed -n '4p')"
    timeout="$(printf '%s' "$resolved" | sed -n '5p')"
    run_exec "$name" "$run" "$cwd" "$image" "$timeout"
    return $?
  fi
  if [ "$rk" = "EMIT" ]; then
    local event payload
    event="$(printf '%s' "$resolved" | sed -n '2p')"
    payload="$(printf '%s' "$resolved" | sed -n '3p')"
    run_emit "$event" "$payload"
    return 0
  fi
  echo "ERR: unhandled participant kind: $rk" >&2; return 2
}

# Lifecycle: started
bus_emit "cortex.workflow.$WF_ID.run.started" \
  "$(jq -nc --arg r "$RUN_ID" --arg id "$WF_ID" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
    '{runId:$r,workflowId:$id,startedAt:$ts}')"

FLOW_LEN="$(printf '%s' "$WF_JSON" | jq -r '.flow | length')"
[ "$FLOW_LEN" -lt 1 ] && { echo "error: flow must be non-empty" >&2; exit 2; }

OVERALL=0
for i in $(seq 0 $((FLOW_LEN-1))); do
  step="$(printf '%s' "$WF_JSON" | jq -c ".flow[$i]")"
  if ! execute_step "$step" 0; then OVERALL=1; break; fi
done

if [ "$OVERALL" = "0" ]; then
  bus_emit "cortex.workflow.$WF_ID.run.completed" \
    "$(jq -nc --arg r "$RUN_ID" --arg id "$WF_ID" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
      '{runId:$r,workflowId:$id,completedAt:$ts,status:"success"}')"
  echo "[cortex-flux] DONE run=$RUN_ID status=success" | tee -a "$RUN_LOG"
  exit 0
fi
bus_emit "cortex.workflow.$WF_ID.run.failed" \
  "$(jq -nc --arg r "$RUN_ID" --arg id "$WF_ID" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
    '{runId:$r,workflowId:$id,failedAt:$ts,status:"failure"}')"
echo "[cortex-flux] DONE run=$RUN_ID status=failure" | tee -a "$RUN_LOG"
exit 1
