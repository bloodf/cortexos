#!/usr/bin/env bash
# cortex-bus-init — provision canonical NATS streams + consumers
# Idempotent. Safe to re-run.
set -u
set -o pipefail

BIN="${CORTEX_BUS:-/opt/cortex/bin/cortex-bus}"

streams=(
  "CORTEX_WORKFLOW|cortex.workflow.>|14d"
  "CORTEX_AGENT|cortex.agent.>|7d"
  "CORTEX_GH|cortex.gh.>,cortex.label.>|3d"
  "CORTEX_SYSTEM|cortex.system.>|1d"
)

for s in "${streams[@]}"; do
  IFS='|' read -r name subjects age <<<"$s"
  if "$BIN" stream-info "$name" >/dev/null 2>&1; then
    echo "[init] stream $name already exists"
  else
    "$BIN" stream-add "$name" "$subjects" --max-age "$age"
    echo "[init] stream $name created subjects=$subjects max-age=$age"
  fi
done

consumers=(
  "CORTEX_AGENT|task-workers|cortex.agent.task.queue|task-workers"
  "CORTEX_WORKFLOW|slack-bridge|cortex.workflow.>|"
  "CORTEX_GH|gh-bridge|cortex.gh.>|"
)

for c in "${consumers[@]}"; do
  IFS='|' read -r stream name filter queue <<<"$c"
  if "$BIN" stream-info "$stream" 2>/dev/null | grep -q "Consumer: $name"; then
    echo "[init] consumer $stream/$name already exists"
  else
    if [ -n "$queue" ]; then
      "$BIN" consumer-add "$stream" "$name" --filter "$filter" --queue "$queue"
    else
      "$BIN" consumer-add "$stream" "$name" --filter "$filter"
    fi
    echo "[init] consumer $stream/$name created filter=$filter queue=$queue"
  fi
done

echo "[init] OK"
