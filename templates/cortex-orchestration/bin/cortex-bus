#!/usr/bin/env bash
# cortex-bus — thin wrapper over NATS CLI for the cortex message bus
# Usage:
#   cortex-bus pub <subject> <payload-json-or-@file>
#   cortex-bus sub <subject-pattern> [--count N]
#   cortex-bus stream-add <name> <subjects-csv> [--retention <interest|workqueue|limits>] [--max-age <Xd>]
#   cortex-bus stream-info <name>
#   cortex-bus stream-ls
#   cortex-bus consumer-add <stream> <name> [--queue <grp>] [--filter <subject>]
#   cortex-bus tap [subject-pattern]            # follow all (or filtered) events
#   cortex-bus emit-workflow-event <repo> <type> <run-id> <payload-json>
#   cortex-bus claim-task <task-id> <worker-id>
#   cortex-bus inbox-send <to-agent> <from-agent> <body>
#
# Env:
#   NATS_URL   nats://127.0.0.1:4222  (default)
#   NATS_BIN   path to nats binary    (default: /usr/local/bin/nats)
set -u
set -o pipefail

NATS_URL="${NATS_URL:-nats://127.0.0.1:4222}"
NATS_BIN="${NATS_BIN:-nats}"
LOG_DIR="${CORTEX_LOG_DIR:-/opt/cortex/logs}"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/bus.jsonl"

log() {
  local kind="$1" subject="$2" status="$3" detail="${4:-}"
  jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" --arg k "$kind" --arg s "$subject" --arg st "$status" --arg d "$detail" \
    '{ts:$ts,kind:$k,subject:$s,status:$st,detail:$d}' >> "$LOG"
}

cmd_pub() {
  local subject="$1" payload="$2"
  if [[ "$payload" == @* ]]; then payload="$(cat "${payload:1}")"; fi
  if "$NATS_BIN" --server="$NATS_URL" pub "$subject" "$payload" >/dev/null 2>&1; then
    log pub "$subject" ok "bytes=${#payload}"
    echo "ok"
  else
    log pub "$subject" fail
    echo "fail" >&2; return 6
  fi
}

cmd_sub() {
  local subject="$1"; shift || true
  local count_arg=()
  if [ "${1:-}" = "--count" ]; then count_arg=(--count "$2"); shift 2; fi
  "$NATS_BIN" --server="$NATS_URL" sub "$subject" "${count_arg[@]}"
}

cmd_stream_add() {
  local name="$1" subjects="$2"; shift 2
  local retention="limits" max_age="14d"
  while [ $# -gt 0 ]; do
    case "$1" in
      --retention) retention="$2"; shift 2 ;;
      --max-age)   max_age="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  "$NATS_BIN" --server="$NATS_URL" stream add "$name" \
    --subjects="$subjects" \
    --retention="$retention" \
    --max-age="$max_age" \
    --storage=file \
    --replicas=1 \
    --discard=old \
    --dupe-window=2m \
    --max-msgs=-1 \
    --max-bytes=-1 \
    --max-msg-size=-1 \
    --defaults
  log stream-add "$name" ok "subjects=$subjects retention=$retention max-age=$max_age"
}

cmd_stream_info()  { "$NATS_BIN" --server="$NATS_URL" stream info "$1"; }
cmd_stream_ls()    { "$NATS_BIN" --server="$NATS_URL" stream ls; }

cmd_consumer_add() {
  local stream="$1" name="$2"; shift 2
  local queue="" filter=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --queue)  queue="$2"; shift 2 ;;
      --filter) filter="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  local args=(--server="$NATS_URL" consumer add "$stream" "$name"
              --pull --deliver=all --ack=explicit --max-deliver=5
              --replay=instant --defaults)
  [ -n "$queue" ]  && args+=(--deliver-group="$queue")
  [ -n "$filter" ] && args+=(--filter="$filter")
  "$NATS_BIN" "${args[@]}"
  log consumer-add "$stream/$name" ok "queue=$queue filter=$filter"
}

cmd_tap() {
  local pattern="${1:->}"
  "$NATS_BIN" --server="$NATS_URL" sub "$pattern"
}

cmd_emit_workflow_event() {
  local repo="$1" type="$2" run_id="$3" payload="$4"
  local subject="cortex.workflow.${repo}.run.${type}"
  local enriched
  enriched="$(jq -nc \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
    --arg repo "$repo" --arg runId "$run_id" --arg type "$type" \
    --argjson p "$payload" \
    '{ts:$ts,repo:$repo,runId:$runId,type:$type} + $p')"
  cmd_pub "$subject" "$enriched"
}

cmd_claim_task() {
  local task_id="$1" worker_id="$2"
  local payload
  payload="$(jq -nc --arg t "$task_id" --arg w "$worker_id" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
    '{taskId:$t,claimedBy:$w,claimedAt:$ts}')"
  cmd_pub "cortex.agent.task.claimed.$task_id" "$payload"
}

cmd_inbox_send() {
  local to="$1" from="$2" body="$3"
  local payload
  payload="$(jq -nc --arg to "$to" --arg from "$from" --arg body "$body" \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)" \
    --arg msgId "$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid)" \
    '{ts:$ts,msgId:$msgId,from:$from,to:$to,body:$body}')"
  cmd_pub "cortex.agent.${to}.inbox" "$payload"
}

main() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    pub)                  cmd_pub "$@" ;;
    sub)                  cmd_sub "$@" ;;
    stream-add)           cmd_stream_add "$@" ;;
    stream-info)          cmd_stream_info "$@" ;;
    stream-ls)            cmd_stream_ls "$@" ;;
    consumer-add)         cmd_consumer_add "$@" ;;
    tap)                  cmd_tap "$@" ;;
    emit-workflow-event)  cmd_emit_workflow_event "$@" ;;
    claim-task)           cmd_claim_task "$@" ;;
    inbox-send)           cmd_inbox_send "$@" ;;
    "" |-h|--help)        sed -n '2,18p' "$0"; exit 0 ;;
    *) echo "unknown subcommand: $sub" >&2; sed -n '2,18p' "$0" >&2; exit 2 ;;
  esac
}

main "$@"
