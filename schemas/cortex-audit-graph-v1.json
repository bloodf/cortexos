{
  "$id": "https://cortexos/schemas/cortex-audit-graph-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cortex.audit.graph.<verb>.v1 data payload",
  "description": "cortex-graph (LangGraph sidecar) audit event covering node lifecycle, human_review interrupts, and resume decisions. Inherits cortex-audit-v1 and constrains `payload` to a graph-node state transition record.",
  "type": "object",
  "required": ["event_id", "event_type", "subject", "payload_hash", "ts", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": {
      "type": "string",
      "pattern": "^cortex\\.audit\\.graph\\.[A-Za-z0-9_-]+\\.v[0-9]+$"
    },
    "actor": { "type": "string" },
    "subject": { "type": "string", "minLength": 1 },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "prev_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ts": { "type": "string", "format": "date-time" },
    "runId": { "type": "string" },
    "agentId": { "type": "string" },
    "role": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["node_id", "node_state", "graph_run_id"],
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the graph node emitting the transition."
        },
        "node_state": {
          "type": "string",
          "enum": ["started", "completed", "failed", "interrupted"],
          "description": "Lifecycle state. 'interrupted' is emitted for human_review checkpoints."
        },
        "graph_run_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the enclosing graph run."
        },
        "checkpoint_id": {
          "type": "string",
          "description": "LangGraph checkpoint id at which the transition occurred."
        },
        "parent_node_id": {
          "type": "string",
          "description": "Immediate predecessor node, for traversal reconstruction."
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Wall-clock duration of the node, when node_state in {'completed','failed'}."
        },
        "error": {
          "type": "string",
          "description": "Error message when node_state = 'failed'."
        },
        "inputs_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of canonicalized node inputs."
        },
        "outputs_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of canonicalized node outputs."
        }
      }
    }
  }
}
