{
  "$id": "https://cortexos/schemas/paperclip-work-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cortex.paperclip.work.<role>.v1 data payload",
  "type": "object",
  "required": ["runId", "issueId", "agentId", "role", "wakeReason", "payload"],
  "additionalProperties": false,
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "issueId": { "type": "string", "minLength": 1 },
    "agentId": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "wakeReason": {
      "type": "string",
      "enum": ["scheduled", "comment", "new_issue", "manual"]
    },
    "payload": { "type": "object" },
    "originalWakeReason": { "type": "string" },
    "requestedBy": { "type": "string" }
  }
}
