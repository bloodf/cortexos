{
  "$id": "https://cortexos/schemas/paperclip-status-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cortex.paperclip.status.<role>.v1 data payload",
  "type": "object",
  "required": ["runId", "issueId", "status", "comment", "costUsdCents"],
  "additionalProperties": false,
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "issueId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "done", "failed", "cancelled", "pending_approval"]
    },
    "comment": { "type": "string" },
    "costUsdCents": { "type": "integer", "minimum": 0 },
    "commitSha": { "type": "string" },
    "reason": { "type": "string" }
  }
}
