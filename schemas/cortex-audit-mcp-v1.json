{
  "$id": "https://cortexos/schemas/cortex-audit-mcp-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cortex.audit.mcp.<verb>.v1 data payload",
  "description": "MCP gateway audit event.",
  "type": "object",
  "required": ["event_id", "event_type", "subject", "payload_hash", "ts", "payload"],
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": {
      "type": "string",
      "pattern": "^cortex\\.audit\\.mcp\\.[A-Za-z0-9_-]+\\.v[0-9]+$"
    },
    "actor": { "type": "string" },
    "subject": { "type": "string", "minLength": 1 },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "prev_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ts": { "type": "string", "format": "date-time" },
    "runId": { "type": "string" },
    "agentId": { "type": "string" },
    "role": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["tool", "tool_class", "args", "result_status"],
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1,
          "description": "Name of the invoked tool."
        },
        "tool_class": {
          "type": "string",
          "enum": ["safe", "destructive"],
          "description": "Risk classification of the tool."
        },
        "args": {
          "type": "object",
          "additionalProperties": true,
          "description": "Arguments passed to the tool. Sensitive values should be redacted by the gateway before audit."
        },
        "confirmation_token": {
          "type": "string",
          "description": "Required when tool_class = 'destructive'. Single-use token issued by the approval flow."
        },
        "result_status": {
          "type": "string",
          "enum": ["ok", "error", "denied"],
          "description": "Outcome of the tool invocation."
        },
        "latency_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Wall-clock latency of the tool call in milliseconds."
        },
        "error": {
          "type": "string",
          "description": "Error message when result_status = 'error' or 'denied'."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "tool_class": { "const": "destructive" } }, "required": ["tool_class"] },
          "then": { "required": ["confirmation_token"] }
        }
      ]
    }
  }
}
