{
  "name": "@cortexos/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --port 3080",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:mocks": "vitest run src/lib/mocks/__tests__/",
    "check:mock-leaks": "bash scripts/check-mock-leaks.sh",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-kit": "^0.28.0",
    "@electric-sql/pglite": "^0.2.0",
    "pg": "^8.20.0",
    "msw": "^2.6.0",
    "@cortexos/contracts": "workspace:*",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "optionalDependencies": {
    "authenticate-pam": "^1.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.6",
    "playwright": "^1.60.0",
    "@types/pg": "^8.11.0",
    "jsdom": "^25.0.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6",
    "zod": "^3.25.0"
  }
}
