# Cortex Dashboard — Environment Variables
# Copy to .env and fill in values for local development.
# Production uses systemd EnvironmentFile at /opt/cortexos/secrets/dashboard.env

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cortex_dashboard
DB_USER=dashboard
DB_PASSWORD=change-me-in-production

# ---------------------------------------------------------------------------
# Auth / PAM (optional)
# ---------------------------------------------------------------------------
# CORTEX_AUTH_PAM_SERVICE=cortexos-dashboard
# CORTEX_AUTH_FAKE_PAM=0

# ---------------------------------------------------------------------------
# Bridge modes (optional — for local dev on macOS/Docker Desktop)
# ---------------------------------------------------------------------------
# CORTEX_DOCKER_BRIDGE_REAL=0
# CORTEX_SYSTEMD_BRIDGE_REAL=0

# ---------------------------------------------------------------------------
# E2E / Test (never set in production)
# ---------------------------------------------------------------------------
# E2E_MOCK_MODE=0
# VITE_E2E=0
