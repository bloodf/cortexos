# dashboard-next — environment variable template
#
# REAL SECRETS MUST NOT go here. This file is a template only.
# Actual secrets are loaded from /opt/cortexos/.secrets/dashboard.env (mode 0600)
# via the EnvironmentFile= directive in cortex-dashboard.service.
#
# Copy the variable NAMES below into .secrets/dashboard.env and fill in real values.

# ---------------------------------------------------------------------------
# Database credentials (supplied by EnvironmentFile)
# ---------------------------------------------------------------------------

# Required. Password for the PostgreSQL 'dashboard' user.
DB_PASSWORD=

# Optional. PostgreSQL host. Default: 127.0.0.1
# DB_HOST=127.0.0.1

# Optional. PostgreSQL port. Default: 5432
# DB_PORT=5432

# Optional. PostgreSQL database name. Default: cortex_dashboard
# DB_NAME=cortex_dashboard

# Optional. PostgreSQL username. Default: dashboard
# DB_USER=dashboard

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Optional. PAM service name for Linux PAM authentication. Default: cortexos-dashboard
# CORTEX_AUTH_PAM_SERVICE=cortexos-dashboard

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Optional. Master key used for signing/encryption. Rotate via .secrets/dashboard.env + systemctl restart.
# CORTEX_MASTER_KEY=
