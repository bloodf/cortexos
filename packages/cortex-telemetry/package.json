{
  "name": "@cortexos/telemetry",
  "version": "0.1.0",
  "description": "CortexOS Node OpenLLMetry + Langfuse wrapper. One-call instrument() + traceLLMCall helper. No-op when LANGFUSE_HOST is unset.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "types": "./src/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@traceloop/node-server-sdk": "^0.27.0",
    "langfuse": "^3.38.20"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "vitest": "^3.2.6"
  }
}
