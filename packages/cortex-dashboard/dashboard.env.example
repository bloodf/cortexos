# Cortex Dashboard environment template.
# Copy to /opt/cortexos/secrets/dashboard.env on the VPS.
# Permissions: chown root:root, chmod 0600. Loaded by cortex-dashboard.service.

# --- HTTP ---
PORT=3080
NODE_ENV=production
HOSTNAME=127.0.0.1
# Comma-separated list of allowed origins for Socket.IO CORS.
DASHBOARD_ORIGIN=https://cortex.example.com

# --- PostgreSQL ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cortex_dashboard
DB_USER=dashboard
DB_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__

# --- Secrets ---
# 32+ byte master key used for credential encryption. Rotate by editing this file
# and restarting cortex-dashboard.service. Never commit.
CORTEX_MASTER_KEY=__REPLACE_WITH_32_BYTE_HEX__

# Optional shared token allowing internal services to bypass auth via header
# x-cortex-internal-token. Defaults to CORTEX_MASTER_KEY when unset.
# CORTEX_INTERNAL_TOKEN=

# --- Agent scanning ---
OPENCLAW_BASE=/home/cortexos/.openclaw
AGENT_SCAN_PATHS=/home/cortexos/.openclaw

# --- Browser terminal SSH backend ---
# The dashboard terminal opens an SSH PTY. Default installs use the operator
# account because OS hardening disables direct root SSH.
TERMINAL_SSH_HOST=127.0.0.1
TERMINAL_SSH_PORT=22
TERMINAL_SSH_USER=cortexos
TERMINAL_SSH_KEY=/opt/cortexos/.secrets/terminal_id_ed25519
# TERMINAL_SSH_PASSWORD=

# --- SSH/deploy hint shown in UI ---
SSH_USER=cortexos

# --- Paperclip integration ---
# Set both URLs when the Paperclip bridge is enabled. PAPERCLIP_API_URL is the
# server-side URL used by the dashboard backend; the NEXT_PUBLIC_ variant is
# read by the sidebar to render the "Paperclip" nav link.
PAPERCLIP_API_URL=
PAPERCLIP_API_KEY_RO=
NEXT_PUBLIC_PAPERCLIP_API_URL=
