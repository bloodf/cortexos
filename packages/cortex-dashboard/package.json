{
  "name": "@cortexos/dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build:next": "next build --turbopack",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node22 --format=cjs --packages=external --outfile=.next/standalone/server.js",
