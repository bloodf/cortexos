{
  "policy_version": 1,
  "tool_classes": {
    "safe": {
      "description": "Read-only operations. No approval required. No rate limit.",
      "requires_confirmation": false,
      "cooldown_seconds": 0
    },
    "privileged": {
      "description": "Reversible mutations. Explicit confirmation token required for every call. Per-role rate limits and cooldown apply.",
      "requires_confirmation": true,
      "auto_approve": false,
      "cooldown_seconds": 0
    },
    "destructive": {
      "description": "Irreversible operations. Explicit operator ack via inbound channel or dashboard confirm + typed slug. Mandatory cooldown. Max 1/hour per tool by default.",
      "requires_confirmation": true,
      "requires_operator_ack": true,
      "default_max_per_hour": 1,
      "cooldown_seconds": 3600
    }
  },
  "tools": [
    {
      "name": "propose_role",
      "class": "safe",
      "description": "Generate an agent role definition proposal from a natural-language description.",
      "args_schema": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "base_role": { "type": "string" }
        }
      }
    },
    {
      "name": "propose_workflow",
      "class": "safe",
      "description": "Generate a workflow YAML proposal for an agent factory.",
      "args_schema": {
        "type": "object",
        "required": ["factory_slug"],
        "properties": {
          "factory_slug": { "type": "string" },
          "stages": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    {
      "name": "propose_pipeline",
      "class": "safe",
      "description": "Generate a CI/CD pipeline proposal for an agent factory.",
      "args_schema": {
        "type": "object",
        "required": ["factory_slug"],
        "properties": {
          "factory_slug": { "type": "string" }
        }
      }
    },
    {
      "name": "propose_project",
      "class": "safe",
      "description": "Generate a project scaffold proposal.",
      "args_schema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "repo_url": { "type": "string" }
        }
      }
    },
    {
      "name": "save_factory",
      "class": "privileged",
      "description": "Persist an agent factory definition to the database.",
      "args_schema": {
        "type": "object",
        "required": ["slug", "kind", "definition"],
        "properties": {
          "slug": { "type": "string" },
          "kind": { "type": "string", "enum": ["role", "workflow", "pipeline", "project"] },
          "definition": { "type": "object" }
        }
      },
      "rate_limit_per_15min": 20
    },
    {
      "name": "validate_factory",
      "class": "safe",
      "description": "Validate a factory definition against its schema without persisting.",
      "args_schema": {
        "type": "object",
        "required": ["kind", "definition"],
        "properties": {
          "kind": { "type": "string" },
          "definition": { "type": "object" }
        }
      }
    },
    {
      "name": "dry_run_dispatch",
      "class": "safe",
      "description": "Simulate dispatching a factory without side effects.",
      "args_schema": {
        "type": "object",
        "required": ["factory_slug"],
        "properties": {
          "factory_slug": { "type": "string" },
          "context": { "type": "object" }
        }
      }
    },
    {
      "name": "vps_status",
      "class": "safe",
      "description": "Read live VPS service status from the host. Read-only; no approval required.",
      "args_schema": {
        "type": "object",
        "properties": {
          "service": { "type": "string" }
        }
      },
      "rate_limit_per_15min": 60
    },
    {
      "name": "service_restart",
      "class": "destructive",
      "description": "Restart a systemd service on the VPS.",
      "args_schema": {
        "type": "object",
        "required": ["service_name"],
        "properties": {
          "service_name": { "type": "string" },
          "confirmation_slug": { "type": "string" }
        }
      },
      "cooldown_seconds": 300,
      "rate_limit_per_15min": 5
    },
    {
      "name": "docker_action",
      "class": "destructive",
      "description": "Perform a Docker action (start/stop/restart/prune) on the VPS.",
      "args_schema": {
        "type": "object",
        "required": ["action", "target"],
        "properties": {
          "action": { "type": "string", "enum": ["start", "stop", "restart", "prune"] },
          "target": { "type": "string" },
          "confirmation_slug": { "type": "string" }
        }
      },
      "cooldown_seconds": 300,
      "rate_limit_per_15min": 5
    },
    {
      "name": "memory_search",
      "class": "privileged",
      "description": "Search Honcho memory store.",
      "args_schema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string" },
          "limit": { "type": "integer", "default": 10 }
        }
      },
      "rate_limit_per_15min": 60
    },
    {
      "name": "env_read",
      "class": "privileged",
      "description": "Read a masked env file from an allowlisted path on the VPS.",
      "args_schema": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" }
        }
      },
      "rate_limit_per_15min": 30
    },
    {
      "name": "env_diff_propose",
      "class": "privileged",
      "description": "Propose a diff to an env file; does not write until confirmed.",
      "args_schema": {
        "type": "object",
        "required": ["path", "updates"],
        "properties": {
          "path": { "type": "string" },
          "updates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["key", "value"],
              "properties": {
                "key": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      },
      "rate_limit_per_15min": 20
    },
    {
      "name": "systemd_action",
      "class": "privileged",
      "description": "Start, stop, or reload a systemd unit (non-restart).",
      "args_schema": {
        "type": "object",
        "required": ["action", "unit"],
        "properties": {
          "action": { "type": "string", "enum": ["start", "stop", "reload", "status"] },
          "unit": { "type": "string" }
        }
      },
      "rate_limit_per_15min": 20
    },
    {
      "name": "docker_prune",
      "class": "destructive",
      "description": "Prune unused Docker resources (volumes/images/networks).",
      "args_schema": {
        "type": "object",
        "required": ["scope"],
        "properties": {
          "scope": { "type": "string", "enum": ["volumes", "images", "networks", "all"] },
          "confirmation_slug": { "type": "string" }
        }
      },
      "cooldown_seconds": 3600
    },
    {
      "name": "alert_ack",
      "class": "privileged",
      "description": "Acknowledge an alert in the dashboard.",
      "args_schema": {
        "type": "object",
        "required": ["alert_id"],
        "properties": {
          "alert_id": { "type": "string" }
        }
      },
      "rate_limit_per_15min": 60
    },
    {
      "name": "agent_factory_promote",
      "class": "destructive",
      "description": "Promote an agent factory definition to active (operator-shell-only; not available via chat).",
      "args_schema": {
        "type": "object",
        "required": ["factory_slug"],
        "properties": {
          "factory_slug": { "type": "string" },
          "confirmation_slug": { "type": "string" }
        }
      },
      "operator_shell_only": true,
      "cooldown_seconds": 300
    }
  ],
  "roles": {
    "cortex": {
      "description": "Cortex VPS helper — broad safe access, scoped privileged, destructive with confirm+cooldown only.",
      "safe": "*",
      "privileged": [
        "save_factory",
        "vps_status",
        "service_restart",
        "docker_action",
        "memory_search",
        "env_read",
        "env_diff_propose",
        "systemd_action",
        "alert_ack"
      ],
      "destructive": [
        "service_restart",
        "docker_action",
        "docker_prune"
      ],
      "destructive_policy": {
        "requires_confirm": true,
        "requires_cooldown": true,
        "max_per_hour": 1
      }
    },
    "factory_agent": {
      "description": "Generated agent factory role — safe + scoped propose/validate tools only.",
      "safe": [
        "propose_role",
        "propose_workflow",
        "propose_pipeline",
        "propose_project",
        "validate_factory",
        "dry_run_dispatch"
      ],
      "privileged": [
        "save_factory"
      ],
      "destructive": []
    }
  }
}
