# Cortex Dashboard .dockerignore
# Keep the build context lean. Source-only; build artifacts and
# host-only tooling are excluded.

# Build artifacts / caches
node_modules
.next
.next/**
.turbo
dist
build
coverage
*.tsbuildinfo

# Git / IDE / OS
.git
.gitignore
.gitattributes
.idea
.vscode
.DS_Store
**/.DS_Store

# Tests & fixtures (not needed at runtime — entrypoint runs prod server)
__tests__
**/__tests__
**/*.test.*
**/*.spec.*
vitest.config.ts
vitest.setup.ts
playwright.config.*
e2e
.playwright

# Env / secrets — NEVER copy into the image
.env
.env.*
*.env
dashboard.env*
.secrets
.secrets/**

# Legacy deploy / systemd (replaced by Compose)
deploy.sh
cortex-dashboard.service
Caddyfile.snippet

# Docs (not needed at runtime)
*.md
docs

# OMC / Claude tooling state
.omc
.claude
AGENTS.md
CLAUDE.md
