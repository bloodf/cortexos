# Cortex Dashboard Caddy Configuration
# Replace {$CORTEX_DOMAIN} with your domain or use environment variable
# Add this to /etc/caddy/Caddyfile on the VPS

{$CORTEX_DOMAIN:localhost} {
    # Dashboard
    reverse_proxy localhost:3080

    # AI Services
    route /9router/* {
        uri strip_prefix /9router
        reverse_proxy localhost:20128
    }
    route /openviking/* {
        uri strip_prefix /openviking
        reverse_proxy localhost:8020
    }
    route /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy localhost:9999
    }
    route /openclaw/* {
        uri strip_prefix /openclaw
        reverse_proxy localhost:18789
    }
    route /ollama/* {
        uri strip_prefix /ollama
        reverse_proxy localhost:11434
    }

    # Infrastructure
    route /nginx/* {
        uri strip_prefix /nginx
        reverse_proxy localhost:8181
    }
    route /cockpit/* {
        uri strip_prefix /cockpit
        reverse_proxy localhost:9090
    }

    # Monitoring
    route /grafana/* {
        uri strip_prefix /grafana
        reverse_proxy localhost:3100
    }
    route /dockpeek/* {
        uri strip_prefix /dockpeek
        reverse_proxy localhost:3420
    }

    # Home
    route /home-assistant/* {
        uri strip_prefix /home-assistant
        reverse_proxy localhost:8123
    }

    # Media
    route /jellyfin/* {
        uri strip_prefix /jellyfin
        reverse_proxy localhost:8096
    }
}

# Direct port access still works for all services
