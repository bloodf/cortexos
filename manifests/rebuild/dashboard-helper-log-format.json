{
  "schema": "cortexos.dashboard.root_helper.command.v1",
  "retention_days": 180,
  "transport": {
    "unix_socket": "/run/cortexos/dashboard-helper.sock",
    "journald_identifier": "cortex-dashboard-root-helper",
    "postgres_table": "dashboard_command_audit"
  },
  "required_fields": [
    "request_id",
    "requested_at",
    "requested_by",
    "command",
    "argv",
    "cwd",
    "target_scope",
    "mutation_class",
    "dry_run",
    "status"
  ],
  "completion_fields": [
    "started_at",
    "finished_at",
    "exit_code",
    "signal",
    "stdout_sha256",
    "stderr_sha256",
    "stdout_bytes",
    "stderr_bytes",
    "journald_cursor"
  ],
  "redaction": {
    "store_secret_values": false,
    "store_stdout_body_by_default": false,
    "store_stderr_body_by_default": false,
    "env_policy": "allowlist_names_only"
  }
}
