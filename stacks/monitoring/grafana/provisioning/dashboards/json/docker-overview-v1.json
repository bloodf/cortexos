{
  "id": null,
  "uid": "docker-overview-v1",
  "title": "Docker Overview",
  "tags": [
    "cortexos",
    "docker"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Container CPU",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_usage_bytes{name!=\"\"}"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network I/O",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(container_network_receive_bytes_total[5m]) or rate(container_network_transmit_bytes_total[5m])"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(container_fs_reads_bytes_total[5m]) or rate(container_fs_writes_bytes_total[5m])"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Container count",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(container_last_seen{name!=\"\"})"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Restarts",
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "changes(container_start_time_seconds{name!=\"\"}[1h])"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    }
  ]
}