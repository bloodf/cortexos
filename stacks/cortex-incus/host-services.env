# CortexOS host-services env — sourced by Incus project creation
# and any operator script that needs the host's Tailscale/bridge
# coordinates.
#
# CORTEX_HOST_FQDN and CORTEX_HOST_BRIDGE must be set in the
# caller's environment before this file is sourced (e.g. from
# /opt/cortexos/.secrets/host.env — encrypted with SOPS+age per
# docs/SECRETS.md). The :? guard below refuses to source if the
# caller forgot to set them, so the leaked MagicDNS name from a
# previous hardcoded version of this file can never reach a
# reverse-proxied config again.

: "${CORTEX_HOST_FQDN:?CORTEX_HOST_FQDN must be set (export it from /opt/cortexos/.secrets/host.env)}"
: "${CORTEX_HOST_BRIDGE:?CORTEX_HOST_BRIDGE must be set (export it from /opt/cortexos/.secrets/host.env)}"

export CORTEX_HOST_FQDN
export CORTEX_HOST_BRIDGE
export CORTEX_AGENTGATEWAY_URL="http://${CORTEX_HOST_BRIDGE}:18800"
export CORTEX_DASHBOARD_URL="https://${CORTEX_HOST_FQDN}"
export CORTEX_9ROUTER_URL="https://${CORTEX_HOST_FQDN}:11434"
