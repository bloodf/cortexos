#!/usr/bin/env bash
set -Eeuo pipefail

cmd="${1:-attach}"
session="${2:-main}"

case "$cmd" in
  attach|a)
    exec tmux new-session -A -s "$session"
    ;;
  list|ls)
    exec tmux list-sessions
    ;;
  new|n)
    exec tmux new-session -s "$session"
    ;;
  choose|c)
    if command -v fzf >/dev/null 2>&1; then
      selected="$(tmux list-sessions -F '#S' 2>/dev/null | fzf --prompt='tmux session> ')"
      [ -n "$selected" ]
      exec tmux attach -t "$selected"
    fi
    exec tmux choose-tree -Zw
    ;;
  restore)
    exec tmux run-shell "$HOME/.tmux/plugins/tmux-resurrect/scripts/restore.sh"
    ;;
  save)
    exec tmux run-shell "$HOME/.tmux/plugins/tmux-resurrect/scripts/save.sh"
    ;;
  kill)
    exec tmux kill-session -t "$session"
    ;;
  *)
    cat <<'USAGE'
Usage: cortex-tmux [attach|list|new|choose|restore|save|kill] [session]
USAGE
    exit 2
    ;;
esac
