#!/usr/bin/env bash
set -Eeuo pipefail

local_only=0
if [ "${1:-}" = "--local-only" ]; then
  local_only=1
fi

if [ -f /etc/cortexos/host-services.env ]; then
  # shellcheck disable=SC1091
  . /etc/cortexos/host-services.env
fi

obot_url="${CORTEX_OBOT_URL:-http://127.0.0.1:8090}"

printf 'obot %s\n' "$obot_url"
if curl -fsS --connect-timeout 2 "$obot_url/" >/dev/null; then
  printf 'obot ok\n'
elif [ "$local_only" -eq 1 ]; then
  printf 'obot unavailable during image build\n'
else
  exit 1
fi

if [ "$local_only" -eq 0 ] && [ -n "${CORTEX_9ROUTER_URL:-}" ]; then
  printf '9router %s\n' "$CORTEX_9ROUTER_URL"
  curl -fsS --connect-timeout 4 "$CORTEX_9ROUTER_URL/health" >/dev/null || true
fi
