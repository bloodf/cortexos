#!/usr/bin/env bash
# honcho-mcp — stdio MCP shim for self-hosted Honcho with per-folder workspace isolation
set -euo pipefail

: "${HONCHO_MCP_URL:?HONCHO_MCP_URL not set}"
: "${HONCHO_API_KEY:?HONCHO_API_KEY not set}"

HONCHO_USER="${HONCHO_USER:-bloodf}"
HONCHO_AGENT_PREFIX="${HONCHO_AGENT_PREFIX:-bloodf-}"
HONCHO_TRANSPORT="${HONCHO_TRANSPORT:-streamablehttp}"

slugify() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/-+/-/g; s/^-//; s/-$//'
}

resolve_project_root() {
  # Claude Code sets CLAUDE_PROJECT_DIR to the real project root for spawned
  # stdio MCP servers. Other harnesses (omp, qwen, gemini) don't, so fall back
  # to $PWD (their MCP child cwd is the launch dir).
  if [ -n "${CLAUDE_PROJECT_DIR:-}" ] && [ -d "${CLAUDE_PROJECT_DIR}" ]; then
    printf '%s' "$CLAUDE_PROJECT_DIR"
  else
    printf '%s' "$PWD"
  fi
}

find_project_file() {
  local d; d="$(resolve_project_root)"
  while [ "$d" != "/" ] && [ -n "$d" ]; do
    for f in ".honcho-project" ".openviking-project"; do
      if [ -f "$d/$f" ]; then
        head -n1 "$d/$f" | tr -d '[:space:]'
        return 0
      fi
    done
    d="$(dirname "$d")"
  done
  return 1
}

derive_workspace_id() {
  if [ -n "${HONCHO_WORKSPACE_ID:-}" ]; then
    printf '%s' "$HONCHO_WORKSPACE_ID"
    return
  fi
  local from_file
  if from_file="$(find_project_file)" && [ -n "$from_file" ]; then
    printf '%s' "$from_file"
    return
  fi
  printf '%s%s' "$HONCHO_AGENT_PREFIX" "$(slugify "$(basename "$(resolve_project_root)")")"
}

WORKSPACE_ID="$(derive_workspace_id)"

echo "honcho-mcp: url=$HONCHO_MCP_URL user=$HONCHO_USER root=$(resolve_project_root) workspace=$WORKSPACE_ID" >&2

exec mcp-proxy \
  --transport "$HONCHO_TRANSPORT" \
  -H Authorization "Bearer ${HONCHO_API_KEY}" \
  -H X-Honcho-User-Name "${HONCHO_USER}" \
  -H X-Honcho-Workspace-ID "${WORKSPACE_ID}" \
  "$HONCHO_MCP_URL"
